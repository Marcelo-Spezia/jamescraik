# Plantilla de configuración. Copiá este archivo a `.env` y completá los valores.
# El archivo `.env` está en .gitignore y NUNCA se sube al repo.

# Credencial de Anthropic (Claude) — necesaria para el JudgeModel real (--live).
# Generala en https://console.anthropic.com -> API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Credencial de Apollo (master key) — necesaria para el enrichment de empresas.
APOLLO_API_KEY=

# Contraseña de acceso a la app desplegada. Si está vacía (dev local), la app queda
# abierta; si la seteás (en Secrets del host), pide contraseña para entrar.
APP_PASSWORD=

# Opcional: modelo del juez (default claude-opus-4-8).
# ICP_JUDGE_MODEL=claude-opus-4-8
# Opcional: tamaño de tanda del enrichment (default 5).
# ICP_ENRICH_BATCH=5
